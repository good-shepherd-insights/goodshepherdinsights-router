# Gateway Configuration (Used for authentication when calling this Router)
GATEWAY_API_KEY=your-gateway-api-key

# Kilocode Provider Configuration (Primary Gateway)
KILOCODE_BASE_URL=https://api.kilo.ai/api/gateway
KILOCODE_API_KEY=sk-kilo-your-api-key

# Local Provider Failover Configuration
MODEL_BASE_URL=http://localhost:8000/v1
LOCAL_MODEL_API_KEY=local-key

# Default routing model
DEFAULT_MODEL=gpt-4o

# Server Configuration
PORT=3000
